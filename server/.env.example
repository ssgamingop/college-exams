# Port for the Express server to listen on
PORT=5001

# MongoDB Connection String
# e.g., mongodb://127.0.0.1:27017/exam_scheduler or mongodb+srv://<username>:<password>@cluster.mongodb.net/exam_scheduler
MONGODB_URI=mongodb://127.0.0.1:27017/exam_scheduler

# Environment Mode (production / development)
NODE_ENV=development

# Password to authenticate database synchronization via the admin UI.
# Use a strong, unique password. On Vercel, set this in Dashboard > Settings > Environment Variables.
ADMIN_PASSWORD=your_secure_admin_password_here

# Secret key for signing JWT session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# On Vercel, set this in Dashboard > Settings > Environment Variables.
JWT_SECRET=your_jwt_secret_here
